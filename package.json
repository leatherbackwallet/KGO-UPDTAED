{
  "name": "keralagiftsonline",
  "version": "3.0.0",
  "description": "KeralGiftsOnline.com - Enterprise-grade hyperlocal marketplace with promotions engine and advanced logistics",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "cd backend && npm run build",
    "build:frontend": "cd frontend && npm run build",
    "start": "concurrently \"npm run start:backend\" \"npm run start:frontend\"",
    "start:backend": "cd backend && npm start",
    "start:frontend": "cd frontend && npm start",
    "seed": "cd backend && npm run seed",
    "seed:v3": "cd backend && node seeds/v3-seeder.js"
  },
  "keywords": [
    "keralagiftsonline",
    "marketplace",
    "hyperlocal",
    "gifts",
    "cakes",
    "flowers",
    "promotions",
    "logistics",
    "enterprise"
  ],
  "author": "KeralGiftsOnline Team",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}

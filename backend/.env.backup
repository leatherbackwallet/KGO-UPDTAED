# Database Configuration
# ⚠️ CRITICAL: ONLY USE MONGODB ATLAS - NEVER USE LOCAL MONGODB
# ❌ DO NOT USE: mongodb://localhost:27017/keralagiftsonline
# ✅ ONLY USE: mongodb+srv://username:password@cluster.mongodb.net/database
MONGODB_URI=mongodb+srv://castlebek:uJrTGo7E47HiEYpf@keralagiftsonline.7oukp55.mongodb.net/?retryWrites=true&w=majority&appName=KeralaGiftsOnline

# JWT Configuration (MUST be at least 32 characters long)
JWT_SECRET=your-super-secret-jwt-key-here-minimum-32-characters-long
JWT_REFRESH_SECRET=your-refresh-token-secret-minimum-32-characters-long

# Admin User Configuration (optional - will use defaults if not set)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=YourSecurePassword123!
ADMIN_PHONE=+1234567890

# Superuser Creation Control
# Set to 'true' to automatically create superuser on server startup
# Set to 'false' or leave unset to skip automatic creation
CREATE_SUPERUSER=false

# Server Configuration
PORT=5001
NODE_ENV=development

# File Upload Configuration
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp

# Cloudinary CDN Configuration
# Get these from https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# CORS Configuration
# Development
CORS_ORIGIN=http://localhost:3000

# Production (update with your deployed frontend URL)
# CORS_ORIGIN=https://your-frontend-domain.com

# Security Configuration
# Rate limiting settings
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX_REQUESTS=5

# Session Configuration
SESSION_SECRET=your-session-secret-minimum-32-characters-long
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=7d

# Logging Configuration
LOG_LEVEL=info

# Razorpay Payment Gateway Configuration
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret
PAYMENT_CURRENCY=INR

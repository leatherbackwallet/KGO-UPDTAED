# Database Configuration
MONGODB_URI=mongodb://localhost:27017/keralagiftsonline

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-here

# Admin User Configuration (optional - will use defaults if not set)
ADMIN_EMAIL=admin@keralagiftsonline.com
ADMIN_PASSWORD=SuperSecure123!
ADMIN_PHONE=+49123456789

# Superuser Creation Control
# Set to 'true' to automatically create superuser on server startup
# Set to 'false' or leave unset to skip automatic creation
CREATE_SUPERUSER=false

# Server Configuration
PORT=5001
NODE_ENV=development

# File Upload Configuration
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# Logging Configuration
LOG_LEVEL=info 
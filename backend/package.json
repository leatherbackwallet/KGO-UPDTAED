{
  "name": "keralagiftsonline-backend",
  "version": "3.0.0",
  "description": "KeralGiftsOnline.com Backend API - Enterprise-grade marketplace with promotions engine",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --exec ts-node server.ts",
    "start": "node dist/server.js",
    "build": "tsc",
    "build:prod": "npm run build && npm prune --production",
    "setup-admin": "node scripts/setup-admin.js",
    "migrate:prices": "ts-node scripts/add-product-prices.ts",
    "migrate:stock": "ts-node scripts/add-product-stock.ts",
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix"
  },
  "keywords": [
    "keralagiftsonline",
    "api",
    "marketplace",
    "promotions",
    "logistics",
    "enterprise"
  ],
  "author": "KeralGiftsOnline Team",
  "license": "MIT",
  "dependencies": {
    "@types/uuid": "^10.0.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.0.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "multer": "^1.4.5-lts.1",
    "node-cache": "^5.1.2",
    "uuid": "^11.1.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.5",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "nodemon": "^3.0.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  }
}

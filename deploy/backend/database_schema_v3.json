{
  "database_name": "keralagiftsonline",
  "description": "Final enterprise-grade schema with a promotions engine, partial fulfillment/shipments, and a fully extensible product attribute system.",
  "collections": {
    "roles": { 
      "description": "Role-Based Access Control (RBAC) definitions.", 
      "fields": {
        "name": { "type": "String", "required": true, "unique": true },
        "description": { "type": "String" },
        "permissions": { "type": "[String]", "required": true },
        "isActive": { "type": "Boolean", "default": true },
        "isDeleted": { "type": "Boolean", "default": false }
      }
    },
    "users": { 
      "description": "Core user management with roles, schedules, and a recipient address book.", 
      "fields": {
        "firstName": { "type": "String", "required": true },
        "lastName": { "type": "String", "required": true },
        "email": { "type": "String", "required": true, "unique": true, "indexed": true, "lowercase": true },
        "password": { "type": "String", "required": true },
        "roleId": { "type": "ObjectId", "ref": "Role", "required": true },
        "phone": { "type": "String", "required": true },
        "location": {
          "type": "Object",
          "description": "GeoJSON location for delivery agents.",
          "structure": {
            "type": { "type": "String", "enum": ["Point"], "default": "Point" },
            "coordinates": { "type": "[Number]" }
          }
        },
        "schedules": {
          "type": "[Object]",
          "description": "Manages future work shifts and time off for vendors and delivery agents.",
          "structure": {
            "type": { "type": "String", "enum": ["work_shift", "time_off"], "required": true },
            "startDate": { "type": "Date", "required": true },
            "endDate": { "type": "Date", "required": true },
            "isRecurring": { "type": "Boolean", "default": false }
          }
        },
        "recipientAddresses": {
          "type": "[Object]",
          "description": "Address book for recipients",
          "structure": {
            "name": { "type": "String", "required": true },
            "phone": { "type": "String", "required": true },
            "address": {
              "type": "Object",
              "required": true,
              "structure": {
                "streetName": { "type": "String", "required": true },
                "houseNumber": { "type": "String", "required": true },
                "postalCode": { "type": "String", "required": true },
                "city": { "type": "String", "required": true },
                "countryCode": { "type": "String", "required": true, "default": "DE" }
              }
            },
            "isDefault": { "type": "Boolean", "default": false }
          }
        },
        "isActive": { "type": "Boolean", "default": true },
        "isDeleted": { "type": "Boolean", "default": false }
      },
      "indexes": [
        {"fields": {"email": 1}, "unique": true},
        {"fields": {"location": "2dsphere"}}
      ]
    },
    "shipments": {
        "description": "Manages partial fulfillment and split shipments for an order. Each shipment links to a specific delivery run.",
        "fields": {
            "shipmentId": { "type": "String", "required": true, "unique": true, "description": "e.g., SHP-ORD123-1" },
            "orderId": { "type": "ObjectId", "ref": "Order", "required": true, "indexed": true },
            "items": {
                "type": "[Object]",
                "required": true,
                "description": "The specific items from the parent order included in this shipment.",
                "structure": {
                    "orderItemId": { "type": "String", "required": true, "description": "A unique ID for the line item from the original order" },
                    "productId": { "type": "ObjectId", "ref": "Product", "required": true },
                    "quantity": { "type": "Number", "required": true }
                }
            },
            "deliveryRunId": { "type": "ObjectId", "ref": "DeliveryRun", "indexed": true },
            "status": { "type": "String", "enum": ["pending_fulfillment", "in_transit", "delivered", "failed_delivery"], "default": "pending_fulfillment", "indexed": true },
            "trackingNumber": { "type": "String" },
            "estimatedDeliveryDate": { "type": "Date" },
            "actualDeliveryDate": { "type": "Date" },
            "notes": { "type": "String" },
            "isDeleted": { "type": "Boolean", "default": false, "indexed": true }
        }
    },
    "orders": {
      "description": "The parent order, which can be fulfilled by one or more shipments.",
      "fields": {
        "orderId": { "type": "String", "required": true, "unique": true },
        "userId": { "type": "ObjectId", "ref": "User", "required": true },
        "requestedDeliveryDate": { "type": "Date", "required": true },
        "shippingDetails": { "type": "Object", "required": true },
        "orderItems": { "type": "[Object]", "required": true },
        "totalPrice": { "type": "Number", "required": true },
        "orderStatus": { "type": "String", "enum": ["pending", "partially_shipped", "shipped", "partially_delivered", "delivered", "cancelled"], "default": "pending", "indexed": true },
        "statusHistory": { "type": "[Object]" },
        "promotionId": { "type": "ObjectId", "ref": "Promotion" },
        "discountAmount": { "type": "Number", "default": 0 },
        "isDeleted": { "type": "Boolean", "default": false, "indexed": true }
      }
    },
    "attributes": {
        "description": "Defines the types of custom fields or properties a product can have (e.g., 'Color', 'Material', 'Occasion').",
        "fields": {
            "name": {
                "type": "Object",
                "required": true,
                "structure": {
                  "en": { "type": "String", "required": true },
                  "de": { "type": "String", "required": true }
                }
            },
            "type": { "type": "String", "enum": ["text", "dropdown", "checkbox_group", "number", "boolean"], "required": true },
            "options": {
                "type": "[Object]",
                "description": "Predefined choices for dropdown or checkbox types.",
                "structure": {
                    "label": { "type": "Object", "structure": { "en": "String", "de": "String" } },
                    "value": { "type": "String" }
                }
            },
            "isRequired": { "type": "Boolean", "default": false },
            "isDeleted": { "type": "Boolean", "default": false, "indexed": true }
        }
    },
    "productAttributes": {
        "description": "A linking collection that assigns a value for a specific attribute to a product.",
        "fields": {
            "productId": { "type": "ObjectId", "ref": "Product", "required": true, "indexed": true },
            "attributeId": { "type": "ObjectId", "ref": "Attribute", "required": true, "indexed": true },
            "value": { "type": "Mixed", "required": true, "description": "The value for the attribute, e.g., 'Red', or ['Gluten-Free', 'Vegan']" }
        },
        "indexes": [{"fields": {"productId": 1, "attributeId": 1}, "unique": true}]
    },
    "products": {
      "description": "Product templates. Specific characteristics are now managed via the 'attributes' system.",
      "fields": {
        "name": { 
          "type": "Object", 
          "required": true,
          "structure": {
            "en": { "type": "String", "required": true },
            "de": { "type": "String", "required": true }
          }
        },
        "description": { 
          "type": "Object", 
          "required": true,
          "structure": {
            "en": { "type": "String", "required": true },
            "de": { "type": "String", "required": true }
          }
        },
        "slug": { "type": "String", "required": true, "unique": true },
        "category": { "type": "ObjectId", "ref": "Category", "required": true },
        "images": { "type": "[String]" },
        "defaultImage": { "type": "String" },
        "isFeatured": { "type": "Boolean", "default": false },
        "isDeleted": { "type": "Boolean", "default": false, "indexed": true }
      }
    },
    "promotions": {
        "description": "An advanced promotions engine with complex rules and actions.",
        "fields": {
            "name": { "type": "String", "required": true, "description": "e.g., Summer Sale 2025" },
            "code": { "type": "String", "unique": true, "description": "Optional coupon code to activate." },
            "conditions": {
                "type": "[Object]",
                "required": true,
                "description": "Rules that must be met for the promotion to apply.",
                "structure": {
                    "type": { "type": "String", "required": true, "description": "e.g., 'cart_total', 'product_in_cart', 'customer_is_new'" },
                    "config": { "type": "Object", "required": true, "description": "Configuration for the rule, e.g., { operator: 'gte', value: 75 }" }
                }
            },
            "actions": {
                "type": "[Object]",
                "required": true,
                "description": "The discounts or effects to apply if conditions are met.",
                "structure": {
                    "type": { "type": "String", "required": true, "description": "e.g., 'apply_free_shipping', 'cart_percentage_discount'" },
                    "config": { "type": "Object", "required": true, "description": "Configuration for the action, e.g., { value: 10 }" }
                }
            },
            "startDate": { "type": "Date" },
            "endDate": { "type": "Date" },
            "isActive": { "type": "Boolean", "default": true, "indexed": true },
            "isDeleted": { "type": "Boolean", "default": false, "indexed": true }
        }
    },
    "categories": { 
      "description": "Product categorization.", 
      "fields": { 
        "name": {
          "type": "Object",
          "required": true,
          "structure": {
            "en": { "type": "String", "required": true },
            "de": { "type": "String", "required": true }
          }
        },
        "slug": { "type": "String", "required": true, "unique": true },
        "description": {
          "type": "Object",
          "structure": {
            "en": { "type": "String" },
            "de": { "type": "String" }
          }
        },
        "parentCategory": { "type": "ObjectId", "ref": "Category" },
        "sortOrder": { "type": "Number", "default": 0 },
        "isActive": { "type": "Boolean", "default": true },
        "isDeleted": { "type": "Boolean", "default": false } 
      } 
    },
    "returns": { 
      "description": "Manages RMA workflows.", 
      "fields": { 
        "returnId": { "type": "String", "required": true, "unique": true },
        "orderId": { "type": "ObjectId", "ref": "Order", "required": true },
        "userId": { "type": "ObjectId", "ref": "User", "required": true },
        "orderItems": { "type": "[Object]", "required": true },
        "reason": { "type": "String", "required": true },
        "status": { "type": "String", "enum": ["requested", "approved", "rejected", "shipped_by_customer", "received_at_hub", "completed"], "default": "requested" },
        "resolution": { "type": "String", "enum": ["refund", "replacement"] },
        "notes": { "type": "String" },
        "isDeleted": { "type": "Boolean", "default": false } 
      } 
    },
    "vendors": { 
      "description": "Vendor management.", 
      "fields": { 
        "ownerId": { "type": "ObjectId", "ref": "User", "required": true },
        "storeName": { "type": "String", "required": true, "unique": true },
        "status": { "type": "String", "enum": ["active", "inactive", "pending_approval", "rejected"], "default": "pending_approval" },
        "address": { "type": "Object", "required": true },
        "location": { "type": "Object" },
        "serviceablePincodes": { "type": "[String]", "required": true },
        "schedules": { "type": "[Object]" },
        "isDeleted": { "type": "Boolean", "default": false } 
      } 
    },
    "hubs": { 
      "description": "Physical packing stations.", 
      "fields": { 
        "name": { "type": "String", "required": true, "unique": true },
        "address": { "type": "Object", "required": true },
        "location": { "type": "Object" },
        "operatingHours": { "type": "String" },
        "isActive": { "type": "Boolean", "default": true },
        "isDeleted": { "type": "Boolean", "default": false } 
      } 
    },
    "deliveryRuns": { 
      "description": "Manages logistical trips.", 
      "fields": { 
        "runId": { "type": "String", "required": true, "unique": true },
        "deliveryAgentId": { "type": "ObjectId", "ref": "User", "required": true },
        "assignedHubId": { "type": "ObjectId", "ref": "Hub", "required": true },
        "orders": { "type": "[ObjectId]", "ref": "Order" },
        "routePlan": { "type": "[Object]", "required": true },
        "status": { "type": "String", "enum": ["planned", "in_progress", "completed", "cancelled"], "default": "planned" },
        "estimatedStartTime": { "type": "Date" },
        "estimatedCompletionTime": { "type": "Date" },
        "actualStartTime": { "type": "Date" },
        "actualCompletionTime": { "type": "Date" },
        "isDeleted": { "type": "Boolean", "default": false } 
      } 
    },
    "vendorProducts": { 
      "description": "Vendor-specific product pricing and availability.", 
      "fields": {
        "vendorId": { "type": "ObjectId", "ref": "Vendor", "required": true },
        "productId": { "type": "ObjectId", "ref": "Product", "required": true },
        "price": { "type": "Number", "required": true },
        "costPrice": { "type": "Number" },
        "stockQuantity": { "type": "Number", "default": 0 },
        "stockType": { "type": "String", "enum": ["in_stock", "low_stock", "out_of_stock"], "default": "in_stock" },
        "stockLevel": { "type": "String", "enum": ["high", "medium", "low"], "default": "medium" },
        "isActive": { "type": "Boolean", "default": true },
        "isDeleted": { "type": "Boolean", "default": false }
      }
    },
    "reviews": { 
      "description": "Multi-faceted review management.", 
      "fields": {
        "userId": { "type": "ObjectId", "ref": "User", "required": true },
        "productId": { "type": "ObjectId", "ref": "Product" },
        "vendorId": { "type": "ObjectId", "ref": "Vendor" },
        "orderId": { "type": "ObjectId", "ref": "Order" },
        "deliveryAgentId": { "type": "ObjectId", "ref": "User" },
        "rating": { "type": "Number", "required": true, "min": 1, "max": 5 },
        "title": { "type": "String" },
        "comment": { "type": "String" },
        "reviewType": { "type": "String", "enum": ["product", "vendor", "delivery"], "default": "product" },
        "isVerified": { "type": "Boolean", "default": false },
        "isDeleted": { "type": "Boolean", "default": false }
      }
    },
    "transactions": { 
      "description": "Payment gateway transaction tracking.", 
      "fields": {
        "orderId": { "type": "ObjectId", "ref": "Order", "required": true },
        "userId": { "type": "ObjectId", "ref": "User", "required": true },
        "amount": { "type": "Number", "required": true },
        "currency": { "type": "String", "default": "INR" },
        "paymentMethod": { "type": "String", "required": true },
        "status": { "type": "String", "enum": ["pending", "completed", "failed", "refunded"], "default": "pending" },
        "gatewayTransactionId": { "type": "String" },
        "gatewayResponse": { "type": "Object" },
        "isDeleted": { "type": "Boolean", "default": false }
      }
    },
    "payouts": { 
      "description": "Vendor payout management.", 
      "fields": {
        "vendorId": { "type": "ObjectId", "ref": "Vendor", "required": true },
        "amount": { "type": "Number", "required": true },
        "currency": { "type": "String", "default": "INR" },
        "status": { "type": "String", "enum": ["pending", "processing", "completed", "failed"], "default": "pending" },
        "payoutMethod": { "type": "String", "required": true },
        "payoutDetails": { "type": "Object" },
        "processedAt": { "type": "Date" },
        "isDeleted": { "type": "Boolean", "default": false } 
      } 
    },
    "ledgers": { 
      "description": "Financial core for income and expense tracking.", 
      "fields": {
        "type": { "type": "String", "enum": ["income", "expense"], "required": true },
        "category": { "type": "String", "required": true },
        "amount": { "type": "Number", "required": true },
        "currency": { "type": "String", "default": "INR" },
        "description": { "type": "String", "required": true },
        "relatedDocument": { "type": "Object" },
        "date": { "type": "Date", "required": true },
        "isDeleted": { "type": "Boolean", "default": false }
      }
    },
    "notifications": { 
      "description": "User notification management.", 
      "fields": {
        "userId": { "type": "ObjectId", "ref": "User", "required": true },
        "title": { "type": "String", "required": true },
        "message": { "type": "String", "required": true },
        "type": { "type": "String", "enum": ["info", "success", "warning", "error"], "default": "info" },
        "isRead": { "type": "Boolean", "default": false },
        "relatedEntity": { "type": "Object" },
        "isDeleted": { "type": "Boolean", "default": false }
      }
    },
    "supportTickets": { 
      "description": "Customer support ticket management.", 
      "fields": {
        "userId": { "type": "ObjectId", "ref": "User", "required": true },
        "subject": { "type": "String", "required": true },
        "description": { "type": "String", "required": true },
        "priority": { "type": "String", "enum": ["low", "medium", "high", "urgent"], "default": "medium" },
        "status": { "type": "String", "enum": ["open", "in_progress", "resolved", "closed"], "default": "open" },
        "assignedTo": { "type": "ObjectId", "ref": "User" },
        "conversation": { "type": "[Object]" },
        "isDeleted": { "type": "Boolean", "default": false } 
      } 
    },
    "activityLogs": { 
      "description": "Audit trail and system activity tracking.", 
      "fields": {
        "userId": { "type": "ObjectId", "ref": "User" },
        "action": { "type": "String", "required": true },
        "entityType": { "type": "String", "required": true },
        "entityId": { "type": "ObjectId" },
        "details": { "type": "Object" },
        "ipAddress": { "type": "String" },
        "userAgent": { "type": "String" },
        "isDeleted": { "type": "Boolean", "default": false }
      }
    },
    "dailyStats": { 
      "description": "Business Intelligence reporting.", 
      "fields": {
        "date": { "type": "Date", "required": true },
        "totalOrders": { "type": "Number", "default": 0 },
        "totalRevenue": { "type": "Number", "default": 0 },
        "totalProducts": { "type": "Number", "default": 0 },
        "totalUsers": { "type": "Number", "default": 0 },
        "topSellingProducts": { "type": "[Object]" },
        "topPerformingVendors": { "type": "[Object]" },
        "isDeleted": { "type": "Boolean", "default": false }
      }
    },
    "pages": { 
      "description": "Simple CMS.", 
      "fields": {
        "title": { "type": "String", "required": true },
        "slug": { "type": "String", "required": true, "unique": true },
        "content": { "type": "String", "required": true },
        "metaDescription": { "type": "String" },
        "isPublished": { "type": "Boolean", "default": false },
        "isDeleted": { "type": "Boolean", "default": false } 
      } 
    },
    "vendorDocuments": { 
      "description": "Vendor verification document management.", 
      "fields": {
        "vendorId": { "type": "ObjectId", "ref": "Vendor", "required": true },
        "documentType": { "type": "String", "required": true },
        "documentNumber": { "type": "String" },
        "fileUrl": { "type": "String", "required": true },
        "status": { "type": "String", "enum": ["pending", "approved", "rejected"], "default": "pending" },
        "verifiedBy": { "type": "ObjectId", "ref": "User" },
        "verifiedAt": { "type": "Date" },
        "notes": { "type": "String" },
        "isDeleted": { "type": "Boolean", "default": false }
      }
    },
    "wishlists": { 
      "description": "User product wishlist management.", 
      "fields": {
        "userId": { "type": "ObjectId", "ref": "User", "required": true },
        "products": { "type": "[ObjectId]", "ref": "Product" },
        "isDeleted": { "type": "Boolean", "default": false } 
      } 
    }
  },
  "metadata": {
    "total_collections": 25,
    "version": "3.0.0",
    "notes": [
      "Version 3.0 represents the final, major architectural design.",
      "Introduces a 'shipments' collection for partial fulfillment.",
      "Features a flexible 'promotions' engine with complex rule-based logic.",
      "Implements a fully extensible 'attributes' system for product details and variations.",
      "All other features like RBAC, i18n, and soft deletes are retained."
    ]
  }
} 
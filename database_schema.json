{
  "database_name": "keralagiftsonline",
  "description": "Complete database schema for a hyperlocal marketplace with advanced logistics and financial management.",
  "collections": {
    "users": {
      "description": "Core user management for customers, vendors, admins, delivery agents, and support staff.",
      "fields": {
        "firstName": { "type": "String", "required": true },
        "lastName": { "type": "String", "required": true },
        "email": { "type": "String", "required": true, "unique": true, "indexed": true, "lowercase": true },
        "password": { "type": "String", "required": true },
        "role": {
          "type": "String",
          "required": true,
          "enum": ["customer", "vendor", "admin", "support_agent", "delivery_agent"],
          "default": "customer"
        },
        "phone": { "type": "String", "required": true }
      }
    },
    "hubs": {
      "description": "Represents physical packing stations or fulfillment centers where gifts are prepared for final delivery.",
      "fields": {
        "name": { "type": "String", "required": true, "unique": true, "description": "e.g., Eschweiler Central Hub" },
        "address": {
          "type": "Object",
          "required": true,
          "structure": {
            "street": { "type": "String", "required": true },
            "city": { "type": "String", "required": true, "default": "Eschweiler" },
            "state": { "type": "String", "required": true, "default": "North Rhine-Westphalia" },
            "postalCode": { "type": "String", "required": true }
          }
        },
        "operatingHours": { "type": "String", "description": "e.g., 9:00 AM - 6:00 PM" },
        "isActive": { "type": "Boolean", "default": true, "indexed": true }
      }
    },
    "deliveryRuns": {
      "description": "Manages a single logistical trip by a delivery agent, including multiple vendor pickups and customer drop-offs.",
      "fields": {
        "runId": { "type": "String", "required": true, "unique": true, "indexed": true, "description": "Human-readable ID, e.g., RUN-20250720-01" },
        "deliveryAgentId": { "type": "ObjectId", "ref": "User", "required": true, "indexed": true },
        "assignedHubId": { "type": "ObjectId", "ref": "Hub", "required": true },
        "status": {
          "type": "String",
          "enum": ["planning", "collecting_items", "at_hub_packing", "out_for_delivery", "completed", "cancelled"],
          "default": "planning",
          "indexed": true
        },
        "orders": { "type": "[ObjectId]", "ref": "Order", "default": [] },
        "routePlan": {
          "type": "[Object]",
          "description": "The ordered sequence of stops for the run.",
          "structure": {
            "stopType": { "type": "String", "enum": ["pickup", "hub", "dropoff"], "required": true },
            "location": { "type": "Object", "required": true },
            "relatedDocument": {
              "type": "Object",
              "structure": {
                "modelName": { "type": "String", "enum": ["Vendor", "Hub", "Order"], "required": true },
                "docId": { "type": "ObjectId", "required": true }
              }
            },
            "status": { "type": "String", "enum": ["pending", "completed", "skipped"], "default": "pending" }
          }
        },
        "estimatedStartTime": { "type": "Date" },
        "actualStartTime": { "type": "Date" },
        "estimatedCompletionTime": { "type": "Date" },
        "actualCompletionTime": { "type": "Date" }
      }
    },
    "orders": {
      "description": "Complete order management with fields for requested delivery dates and linkage to a delivery run.",
      "fields": {
        "orderId": { "type": "String", "required": true, "unique": true, "indexed": true },
        "userId": { "type": "ObjectId", "ref": "User", "required": true, "indexed": true },
        "requestedDeliveryDate": { "type": "Date", "required": true, "indexed": true },
        "requestedDeliveryTimeSlot": { "type": "String", "description": "e.g., Morning (9am-1pm)" },
        "deliveryRunId": { "type": "ObjectId", "ref": "DeliveryRun", "indexed": true },
        "shippingDetails": {
          "type": "Object",
          "required": true,
          "structure": {
            "name": { "type": "String", "required": true },
            "phone": { "type": "String", "required": true },
            "address": { "type": "Object", "required": true }
          }
        },
        "orderItems": {
          "type": "[Object]",
          "required": true,
          "structure": {
            "productId": { "type": "ObjectId", "ref": "Product", "required": true },
            "name": { "type": "String", "required": true },
            "price": { "type": "Number", "required": true },
            "quantity": { "type": "Number", "required": true },
            "vendorId": { "type": "ObjectId", "ref": "Vendor", "required": true }
          }
        },
        "totalPrice": { "type": "Number", "required": true },
        "orderStatus": {
          "type": "String",
          "enum": ["pending", "processing", "awaiting_delivery_run", "out_for_delivery", "delivered", "cancelled"],
          "default": "pending",
          "indexed": true
        },
        "paymentDetails": { "type": "Object" },
        "taxDetails": { "type": "Object", "required": true },
        "discountAmount": { "type": "Number", "default": 0 },
        "appliedCouponCode": { "type": "String" }
      }
    },
    "categories": {
      "description": "Product categorization with hierarchical structure.",
      "fields": {
        "name": { "type": "String", "required": true, "unique": true },
        "slug": { "type": "String", "required": true, "unique": true, "lowercase": true },
        "parentCategory": { "type": "ObjectId", "ref": "Category" },
        "image": { "type": "String" }
      }
    },
    "products": {
      "description": "Product templates with personalization options.",
      "fields": {
        "name": { "type": "String", "required": true, "unique": true },
        "slug": { "type": "String", "required": true, "unique": true, "lowercase": true },
        "description": { "type": "String", "required": true },
        "category": { "type": "ObjectId", "ref": "Category", "required": true, "indexed": true },
        "defaultImage": { "type": "String" },
        "tags": { "type": "[String]", "indexed": true },
        "personalizationOptions": { "type": "[Object]", "default": [] },
        "isActive": { "type": "Boolean", "default": true, "indexed": true }
      }
    },
    "vendors": {
      "description": "Marketplace vendor management with store information.",
      "fields": {
        "ownerId": { "type": "ObjectId", "ref": "User", "required": true, "indexed": true },
        "storeName": { "type": "String", "required": true, "unique": true },
        "status": { "type": "String", "enum": ["active", "inactive", "pending_approval", "rejected"], "default": "pending_approval", "indexed": true },
        "address": { "type": "Object", "required": true },
        "serviceablePincodes": { "type": "[String]", "required": true, "indexed": true },
        "averageRating": { "type": "Number", "default": 0 }
      }
    },
    "vendorProducts": {
      "description": "Vendor-specific product pricing and tax information. Can be extended for inventory.",
      "fields": {
        "vendorId": { "type": "ObjectId", "ref": "Vendor", "required": true, "indexed": true },
        "productId": { "type": "ObjectId", "ref": "Product", "required": true, "indexed": true },
        "price": { "type": "Number", "required": true },
        "hsnCode": { "type": "String", "required": true },
        "taxRate": { "type": "Number", "required": true, "enum": [0, 5, 12, 18, 28] },
        "stockType": { "type": "String", "enum": ["infinite", "finite", "daily_capacity"], "default": "infinite" },
        "stockLevel": { "type": "Number" },
        "isActive": { "type": "Boolean", "default": true, "indexed": true }
      }
    },
    "reviews": {
      "description": "Product, vendor, and delivery review management.",
      "fields": {
        "reviewType": { "type": "String", "enum": ["product", "vendor", "delivery"], "required": true, "indexed": true },
        "productId": { "type": "ObjectId", "ref": "Product" },
        "vendorId": { "type": "ObjectId", "ref": "Vendor" },
        "deliveryAgentId": { "type": "ObjectId", "ref": "User" },
        "userId": { "type": "ObjectId", "ref": "User", "required": true },
        "orderId": { "type": "ObjectId", "ref": "Order", "required": true, "indexed": true },
        "rating": { "type": "Number", "required": true, "min": 1, "max": 5 },
        "comment": { "type": "String" },
        "reply": { "type": "Object" }
      }
    },
    "coupons": { "description": "Promotional coupon and discount management.", "fields": {} },
    "transactions": { "description": "Payment gateway transaction tracking.", "fields": {} },
    "payouts": { "description": "Vendor payout management and tracking.", "fields": {} },
    "ledgers": { "description": "Financial core for income and expense tracking.", "fields": {} },
    "notifications": { "description": "User notification management (for future use).", "fields": {} },
    "supportTickets": { "description": "Customer support ticket management.", "fields": {} },
    "activityLogs": { "description": "Audit trail and system activity tracking.", "fields": {} },
    "dailyStats": { "description": "Business Intelligence reporting and analytics.", "fields": {} },
    "pages": { "description": "Simple CMS for static page management.", "fields": {} },
    "vendorDocuments": { "description": "Vendor verification document management.", "fields": {} },
    "wishlists": { "description": "User product wishlist management.", "fields": {} }
  },
  "metadata": {
    "total_collections": 21,
    "version": "1.1.0",
    "notes": [
      "All collections include automatic timestamps (createdAt, updatedAt).",
      "Introduced advanced logistics management with 'hubs' and 'deliveryRuns' collections.",
      "Schema supports GST compliance and detailed financial tracking.",
      "Designed for a hyperlocal, multi-pickup, multi-dropoff business model."
    ]
  }
} 